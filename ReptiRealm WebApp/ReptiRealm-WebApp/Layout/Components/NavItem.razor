<div class="nav-item">
    <NavLink class="nav-link"
             href="@Href"
             Match="@Match">
        <span class="bi @Icon" aria-hidden="true"></span>
        @Text
    </NavLink>
</div>

@code {
    [Parameter]
    public string Icon { get; set; } = "";

    [Parameter]
    public string Text { get; set; } = "";

    [Parameter]
    public string Href { get; set; } = "";

    [Parameter]
    public NavLinkMatch Match { get; set; } = NavLinkMatch.Prefix;
}
