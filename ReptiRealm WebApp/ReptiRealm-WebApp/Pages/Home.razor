@page "/"

<PageTitle>Home</PageTitle>

<p>Welcome to ReptiRealm!</p>

@code {
    <!-- HEADER CONTENT -->
    protected override void OnInitialized()
    {
        HeaderState.SetHeader(new HeaderData
        {
            Heading = "ReptiRealm",
            SubHeading = "Track feeds, sheds, weight, and health events for your reptiles",
            ButtonText = "Add Reptile",
            ButtonIcon = "+",
            ButtonAction = AddReptile
        });
    }

    private async Task AddReptile()
    {
        Navigation.NavigateTo("/reptile/create");
    }

